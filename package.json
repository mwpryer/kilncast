{
  "name": "kilncast",
  "version": "0.1.2",
  "description": "Thin typed wrapper over both Firestore SDKs",
  "license": "MIT",
  "author": "mwpryer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwpryer/kilncast.git"
  },
  "files": [
    "dist",
    "skills"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "import": "./dist/admin.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "firebase emulators:exec --only firestore --project kilncast 'bun test'",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "format": "bun run lint:fix && bun run fmt",
    "preversion": "bun run typecheck && bun run lint && bun run fmt:check && bun run test",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "firebase-tools": "^15.16.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsup": "^8.5.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "firebase": "^11.0.0 || ^12.0.0",
    "firebase-admin": "^12.0.0 || ^13.0.0 || ^14.0.0"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    }
  }
}
